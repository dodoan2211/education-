rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && (
        ('email' in request.auth.token && request.auth.token.email == "dodoan2211@gmail.com") ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('package', 'free') == "admin"
        )
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /consignments/{consignmentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /resources/{resourceId} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        ('isShared' in resource.data && resource.data.isShared == true) || 
        ('shareCode' in resource.data && resource.data.shareCode != null)
      ));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        ('isShared' in resource.data && resource.data.isShared == true) || 
        ('shareCode' in resource.data && resource.data.shareCode != null)
      ));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /resource_notes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /resource_versions/{versionId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    match /competitions/{compId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /submissions/{subId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /transactions/{txId} {
      allow read, write: if isSignedIn();
    }

    match /conversations/{convId} {
      allow read, write: if isSignedIn();
    }

    match /messages/{msgId} {
      allow read, write: if isSignedIn();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.followerId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
